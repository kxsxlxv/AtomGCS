# === VS Code ===
.vscode/*
# Исключение: сохраняем настройки запуска и задачи, если они общие для команды
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
# Игнорируем историю и временные расширения
.history/
*.code-workspace

# === CMake ===
CMakeCache.txt
CMakeFiles/
CMakeSettings.json
cmake_install.cmake
install_manifest.txt
compile_commands.json

# === Системные файлы ===
.DS_Store
Thumbs.db

# === Логи и временные файлы ===
*.log
*.tmp



