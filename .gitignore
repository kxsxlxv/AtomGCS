# === Результаты сборки (Build outputs) ===
build/
bin/
lib/
out/
.cache/

# === Временные файлы компилятора и линкера ===
*.obj
*.o
*.pdb
*.exe
*.dll
*.so
*.a
*.lib
*.ilk
*.exp

# === Visual Studio (Windows) ===
.vs/
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.suo
*.db
*.opendb
